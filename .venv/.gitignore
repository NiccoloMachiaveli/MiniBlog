# Keep IDE folder out of VCS except this placeholder
*
!.gitignore

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Environment and local config
.env
.env.*
.python-version

# IDE/editor files
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db